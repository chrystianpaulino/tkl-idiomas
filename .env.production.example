# =============================================================================
# EduGest -- production environment template
# =============================================================================
# Copy to `.env` on the production host and fill in EVERY blank value.
# Lines marked `# CRITICAL:` change a security or correctness invariant --
# do NOT relax them without explicit reasoning recorded in your runbook.
# -----------------------------------------------------------------------------

APP_NAME="EduGest"
APP_ENV=production
# Generate once during deployment with `php artisan key:generate --show`
# and write it here. Rotating this value invalidates every active session
# and every signed URL (including pending invite links), so treat it as
# a long-lived secret and rotate only with planned downtime.
APP_KEY=
# CRITICAL: must remain false in production. Setting true reveals stack
# traces, environment dumps, and bound DB credentials to anyone hitting
# an error page.
APP_DEBUG=false
APP_TIMEZONE=UTC
# Set to the public HTTPS URL so route() / signed URLs / mail links
# resolve correctly. The invite emails embed routes generated from this
# value -- a wrong APP_URL means recipients can't accept invites.
APP_URL=https://app.example.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# `stack` aggregates the channels in LOG_STACK. `daily` rotates by day with
# 14 day retention -- enough headroom for ad-hoc post-mortems without
# unbounded disk growth.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
# Audit log retention (days). 90 days covers the typical incident response
# window. Increase for regulated tenants if needed.
LOG_AUDIT_DAYS=90

# -----------------------------------------------------------------------------
# Database (MySQL 8 / MariaDB 10.6+)
# -----------------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session / cache / queue
# -----------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Set to your apex (e.g. `.example.com`) when serving from a subdomain so
# session cookies follow the user across www / app subdomains.
SESSION_DOMAIN=
# CRITICAL: must be true behind HTTPS. Browsers will refuse to send the
# session cookie over plain HTTP, which is the desired behaviour in prod.
SESSION_SECURE_COOKIE=true
# Mitigates CSRF for older browsers. `lax` is the framework default and
# right for invite links opened from email clients (POST is still
# protected by the CSRF token).
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=edugest_

# -----------------------------------------------------------------------------
# Mail (Brevo / Sendinblue SMTP relay)
# -----------------------------------------------------------------------------
# 1. Sign in to Brevo, generate an SMTP key under SMTP & API.
# 2. Verify your sending domain (DKIM + SPF + return-path).
# 3. Fill the values below. MAIL_FROM_ADDRESS MUST belong to the verified
#    domain or every invite email will land in spam (or be rejected).

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Reverse proxy / TLS termination
# -----------------------------------------------------------------------------
# Comma-separated list of trusted proxies (load balancer / CDN). Required
# so request()->ip() returns the real client IP behind X-Forwarded-For
# (the audit log relies on that for accurate attribution).
TRUSTED_PROXIES=

# -----------------------------------------------------------------------------
# Object storage (optional -- used by Material upload disk)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Vite (build-time)
# -----------------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"
